{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Run Airframe GPU Server",
			"type": "process",
			"command": "cargo",
			"args": [
				"run",
				"--release",
				"--bin",
				"shimmy_server_gpu"
			],
			"options": {
				"env": {
					"RUST_BACKTRACE": "1",
					"SHIMMY_PORT": "8080"
				}
			},
			"isBackground": true,
			"problemMatcher": [
				{
					"owner": "custom",
					"pattern": {
						"regexp": "^(.*)$",
						"message": 1
					},
					"background": {
						"activeOnStart": true,
						"beginsPattern": ".",
						"endsPattern": "\\[HTTP\\] Async listener spawned on .+"
					}
				}
			],
			"presentation": {
				"panel": "dedicated",
				"reveal": "always",
				"clear": false
			},
			"group": "build"
		},
		{
			"label": "Validate Airframe Short SHA",
			"type": "process",
			"command": "powershell",
			"args": [
				"-ExecutionPolicy",
				"Bypass",
				"-File",
				"${workspaceFolder}\\scripts\\short_story_sha_check.ps1"
			],
			"isBackground": false,
			"presentation": {
				"panel": "dedicated",
				"reveal": "always",
				"clear": false
			},
			"group": "build"
		},
		{
			"label": "Validate Airframe Long Story",
			"type": "process",
			"command": "powershell",
			"args": [
				"-ExecutionPolicy",
				"Bypass",
				"-File",
				"${workspaceFolder}\\scripts\\long_story_check.ps1"
			],
			"isBackground": false,
			"presentation": {
				"panel": "dedicated",
				"reveal": "always",
				"clear": false
			},
			"group": "build"
		},

		{
			"label": "Validate Card Smoke (Shadow)",
			"type": "process",
			"command": "powershell",
			"args": [
				"-ExecutionPolicy",
				"Bypass",
				"-File",
				"${workspaceFolder}\\scripts\\card_smoke_check.ps1",
				"-CardProcessingMode",
				"shadow"
			],
			"isBackground": false,
			"presentation": {
				"panel": "dedicated",
				"reveal": "always",
				"clear": false
			},
			"group": "build"
		},
		{
			"label": "Validate Card Smoke (On)",
			"type": "process",
			"command": "powershell",
			"args": [
				"-ExecutionPolicy",
				"Bypass",
				"-File",
				"${workspaceFolder}\\scripts\\card_smoke_check.ps1",
				"-CardProcessingMode",
				"on"
			],
			"isBackground": false,
			"presentation": {
				"panel": "dedicated",
				"reveal": "always",
				"clear": false
			},
			"group": "build"
		},
		{
			"label": "U: Validate Airframe Default Path",
			"dependsOrder": "sequence",
			"dependsOn": [
				"Run Airframe GPU Server",
				"Validate Airframe Short SHA",
				"Validate Airframe Long Story"
			],
			"group": "build"
		},
		{
			"label": "Run Model Smoke Test",
			"type": "process",
			"command": "powershell",
			"args": [
				"-ExecutionPolicy",
				"Bypass",
				"-File",
				"${workspaceFolder}\\scripts\\model_smoke_test.ps1"
			],
			"isBackground": false,
			"presentation": {
				"panel": "dedicated",
				"reveal": "always",
				"clear": true
			},
			"group": "build"
		},

		{
			"label": "U: Validate Card Shadow Path",
			"dependsOrder": "sequence",
			"dependsOn": [
				"Run Airframe GPU Server",
				"Validate Card Smoke (Shadow)"
			],
			"group": "build"
		},
		{
			"label": "U: Validate Card On Path",
			"dependsOrder": "sequence",
			"dependsOn": [
				"Run Airframe GPU Server",
				"Validate Card Smoke (On)"
			],
			"group": "build"
		},
		{
			"label": "Run Shimmy Chat",
			"type": "process",
			"command": "cargo",
			"args": [
				"run",
				"--release",
				"-p",
				"shimmy-console",
				"--bin",
				"shimmy-console",
				"--",
				"chat"
			],
			"isBackground": false,
			"presentation": {
				"panel": "dedicated",
				"reveal": "always",
				"clear": false
			},
			"group": "build"
		},
		{
			"label": "Run Airframe GPU Server (custom model)",
			"type": "process",
			"command": "cargo",
			"args": ["run", "--release", "--bin", "shimmy_server_gpu"],
			"options": {
				"env": {
					"RUST_BACKTRACE": "1",
					"SHIMMY_PORT": "8080",
					"LIBSHIMMY_MODEL_PATH": "${input:airframeModelPath}"
				}
			},
			"isBackground": true,
			"problemMatcher": [{
				"owner": "custom",
				"pattern": { "regexp": "^(.*)$", "message": 1 },
				"background": {
					"activeOnStart": true,
					"beginsPattern": ".",
					"endsPattern": "\\[HTTP\\] Async listener spawned on .+"
				}
			}],
			"presentation": { "panel": "dedicated", "reveal": "always", "clear": true },
			"group": "build"
		},
		{
			"label": "Run Airframe GPU Server (8K ctx)",
			"type": "process",
			"command": "cargo",
			"args": ["run", "--release", "--bin", "shimmy_server_gpu"],
			"options": {
				"env": {
					"RUST_BACKTRACE": "1",
					"SHIMMY_PORT": "8080",
					"SHIMMY_MAX_CTX": "8192"
				}
			},
			"isBackground": true,
			"problemMatcher": [{
				"owner": "custom",
				"pattern": { "regexp": "^(.*)$", "message": 1 },
				"background": {
					"activeOnStart": true,
					"beginsPattern": ".",
					"endsPattern": "\\[HTTP\\] Async listener spawned on .+"
				}
			}],
			"presentation": { "panel": "dedicated", "reveal": "always", "clear": false },
			"group": "build"
		},
		{
			"label": "Run Needle Bench (2K ctx)",
			"type": "process",
			"command": "python",
			"args": ["scripts/needle_bench.py", "--ctx", "2048", "--depths", "15,50,85", "--runs", "3", "--timeout", "300", "--out", "artifacts/needle_bench_2k.json"],
			"isBackground": false,
			"presentation": { "panel": "dedicated", "reveal": "always", "clear": true },
			"group": "build"
		},
		{
			"label": "Run Phi Smoke + Formula (bash)",
			"type": "process",
			"command": "bash",
			"args": [
				"scripts/phi_smoke_formula.sh"
			],
			"options": {
				"env": {
					"MODEL_PATH": "${input:phiModelPath}",
					"PROFILE": "phi2_smoke_formula"
				}
			},
			"isBackground": false,
			"presentation": {
				"panel": "dedicated",
				"reveal": "always",
				"clear": true
			},
			"group": "build"
		},
		{
			"label": "Run Needle Bench (4K ctx)",
			"type": "process",
			"command": "python",
			"args": ["scripts/needle_bench.py", "--ctx", "4096", "--depths", "15,50,85", "--runs", "3", "--timeout", "900", "--out", "artifacts/needle_bench_4k.json"],
			"isBackground": false,
			"presentation": { "panel": "dedicated", "reveal": "always", "clear": true },
			"group": "build"
		},
		{
			"label": "Run Needle Bench (8K ctx)",
			"type": "process",
			"command": "python",
			"args": ["scripts/needle_bench.py", "--ctx", "8192", "--depths", "15,50,85", "--runs", "3", "--timeout", "2400", "--out", "artifacts/needle_bench_8k.json"],
			"isBackground": false,
			"presentation": { "panel": "dedicated", "reveal": "always", "clear": true },
			"group": "build"
		},
		{
			"label": "Run Needle Bench (Full Matrix 2K-8K)",
			"type": "process",
			"command": "python",
			"args": ["scripts/needle_bench.py", "--ctx", "2048,4096,8192", "--depths", "10,25,50,75,90", "--runs", "3", "--timeout", "2400", "--out", "artifacts/needle_bench_full.json"],
			"isBackground": false,
			"presentation": { "panel": "dedicated", "reveal": "always", "clear": true },
			"group": "build"
		},
		{
			"label": "U: Needle Smoke (2K, default server)",
			"dependsOrder": "sequence",
			"dependsOn": ["Run Airframe GPU Server", "Run Needle Bench (2K ctx)"],
			"group": "build"
		},
		{
			"label": "U: Needle Full Matrix (8K server)",
			"dependsOrder": "sequence",
			"dependsOn": ["Run Airframe GPU Server (8K ctx)", "Run Needle Bench (Full Matrix 2K-8K)"],
			"group": "build"
		}
	],
	"inputs": [
		{
			"id": "phiModelPath",
			"type": "promptString",
			"description": "Absolute GGUF path for Phi smoke harness (MODEL_PATH)",
			"default": "D:\\shimmy-test-models\\gguf_collection\\phi-2.Q4_K_M.gguf"
		},
		{
			"id": "airframeModelPath",
			"type": "promptString",
			"description": "Absolute GGUF path for shimmy_server_gpu (LIBSHIMMY_MODEL_PATH)",
			"default": "D:\\shimmy-test-models\\gguf_collection\\TinyLlama-1.1B-Chat-v1.0.Q4_0.gguf"
		}
	]
}