{
  "$schema": "https://opencode.ai/config.json",
  
  "model": "groq/gpt-oss-120b",
  "small_model": "groq/gpt-oss-120b",

  "skills": {
    "paths": [
      ".opencode/skills"
    ]
  },

  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 1024
  },

  "watcher": {
    "ignore": [
      ".git/**",
      "node_modules/**",
      "dist/**",
      "build/**",
      "vendor/**",
      "coverage/**",
      "tmp/**",
      "logs/**",
      "*.log",

      "target/**",
      ".cargo/**",

      "**/*.wasm",
      "**/*.bin",
      "**/*.rlib",
      "**/*.rmeta",
      "**/*.lock"
    ]
  },

  "provider": {
    "groq": {
      "models": {
        "gpt-oss-120b": {
          "limit": {
            "context": 131072,
            "input": 131072,
            "output": 1024
          }
        }
      },
      "options": {
        "timeout": 600000
      }
    }
  },

  "permission": {
    "bash": "ask",
    "edit": "allow",
    "read": "allow",
    "write": "allow"
  }
}