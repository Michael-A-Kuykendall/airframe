{
  "$schema": "https://opencode.ai/config.json",
  
  "model": "local-model",
  "small_model": "local-model",

  "skills": {
    "paths": [
      ".opencode/skills"
    ]
  },

  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 1024
  },

  "watcher": {
    "ignore": [
      ".git/**",
      "node_modules/**",
      "dist/**",
      "build/**",
      "vendor/**",
      "coverage/**",
      "tmp/**",
      "logs/**",
      "*.log",

      "target/**",
      ".cargo/**",

      "**/*.wasm",
      "**/*.bin",
      "**/*.rlib",
      "**/*.rmeta",
      "**/*.lock"
    ]
  },

  "provider": {
    "custom": {
      "baseUrl": "http://localhost:1234/v1",
      "apiKey": "dummy-key"
    }
  },
  "model": "gemma-4-12b-coder-fable5-composer2.5-v1",

  "permission": {
    "bash": "ask",
    "edit": "allow",
    "read": "allow",
    "write": "allow"
  }
}